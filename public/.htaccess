DirectoryIndex index.html

RewriteEngine On

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.tcpartners\.com\.br$ [NC]
RewriteRule ^ https://tcpartners.com.br%{REQUEST_URI} [L,R=301]

<IfModule mod_headers.c>
  <FilesMatch "^(index\.html|sw\.js|registerSW\.js|site\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
