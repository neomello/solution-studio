---
import { Image } from 'astro:assets';
const splashVersion = Date.now().toString(36);
---

<div class="splash" id="splash" data-splash-version={splashVersion} role="presentation" aria-label="Carregando Studio Odonto">

  <div class="splash-scene">
    <Image
      src="/logo_horiz.svg"
      alt="Studio Odonto Logo"
      class="splash-logo"
      width="434"
      height="145"
      priority
    />
  </div>

</div>

<script>
  (function () {
    const splash = document.getElementById('splash');
    if (!splash) return;
    const splashKey = `so_splash_seen:${splash.dataset.splashVersion || 'static'}`;

    function hasSeenSplash() {
      try {
        return sessionStorage.getItem(splashKey) === '1';
      } catch {
        return false;
      }
    }

    function markSplashSeen() {
      try {
        sessionStorage.setItem(splashKey, '1');
      } catch {
        // Ignorar se o storage não estiver disponível
      }
    }

    if (hasSeenSplash()) {
      splash.remove();
      return;
    }

    function dismiss() {
      markSplashSeen();
      splash.classList.add('splash--out');
      setTimeout(() => splash.remove(), 600);
    }

    // Aguarda um momento para mostrar a logo e então remove a splash
    setTimeout(dismiss, 1800);

    // Skippável
    splash.addEventListener('click', dismiss, { once: true });
    document.addEventListener('keydown', dismiss, { once: true });
  })();
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: #F7F5F0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .splash--out {
    opacity: 0;
    pointer-events: none;
  }

  .splash-scene {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    animation: fadeScaleIn 800ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .splash-logo {
    width: min(80vw, 300px);
    height: auto;
    object-fit: contain;
  }

  @keyframes fadeScaleIn {
    from {
      opacity: 0;
      transform: scale(0.9);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .splash {
      display: none;
    }
  }
</style>
