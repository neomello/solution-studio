<div class="status-badge">
  <span class="status-dot" aria-hidden="true"></span>
  <span class="status-label">SOLUTION Studio Odonto</span>
</div>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--color-glass-surface);
    border: 1px solid var(--color-glass-border);
    border-radius: 999px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #DB9E16;
    box-shadow: 0 0 8px rgba(219, 158, 22, 0.6);
    animation: dot-pulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  .status-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(0, 0, 0, 0.6);
    text-transform: uppercase;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.6; box-shadow: 0 0 6px rgba(219, 158, 22, 0.4); }
    50% { opacity: 1; box-shadow: 0 0 12px rgba(219, 158, 22, 0.8); }
  }

  @media (max-width: 767px) {
    .status-badge {
      max-width: 100%;
      padding: 5px 11px;
      gap: 7px;
    }

    .status-label {
      font-size: 9px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }
</style>
