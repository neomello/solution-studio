---
---

<div class="status-bar fade-in" role="status" aria-label="Localização e horário">
  <div class="status-track">
    <span class="status-location-wrap">
      <svg class="location-icon" width="9" height="9" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
      </svg>
      <span class="status-location">Itajaí · SC · Brasil</span>
    </span>

    <span class="status-coords">−26°54' −48°39'</span>

    <span class="status-clock-wrap">
      <svg class="clock-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
      <time class="status-clock" id="itajai-clock" datetime="">--:--</time>
    </span>
  </div>
</div>

<script>
  (function () {
    const el = document.getElementById('itajai-clock');
    if (!el) return;

    function update() {
      const now = new Date();
      const itajaiTime = new Intl.DateTimeFormat('pt-BR', {
        timeZone: 'America/Sao_Paulo',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false,
      }).format(now);
      el.textContent = itajaiTime;
      el.setAttribute('datetime', now.toISOString());
    }

    update();
    setInterval(update, 1000);
  })();
</script>

<style>
  .status-bar {
    position: fixed;
    top: env(safe-area-inset-top, 0px);
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    background: linear-gradient(180deg, rgba(0, 5, 34, 0.8) 0%, transparent 100%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .status-track {
    width: 100%;
    max-width: 420px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 10px;
  }

  .status-location,
  .status-coords,
  .status-clock {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.42);
  }

  .status-location-wrap {
    display: flex;
    align-items: center;
    gap: 3px;
    color: rgba(255, 255, 255, 0.3);
    justify-self: start;
    min-width: 0;
  }

  .location-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .status-clock-wrap {
    display: flex;
    align-items: center;
    gap: 3px;
    color: rgba(2, 184, 249, 0.55);
    justify-self: end;
  }

  .clock-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .status-clock {
    font-feature-settings: 'tnum';
  }

  .status-coords {
    justify-self: center;
  }

  @media (max-width: 380px) {
    .status-track {
      grid-template-columns: 1fr auto;
    }

    .status-coords {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .status-bar {
      padding: 7px 16px;
    }

    .status-track {
      gap: 8px;
    }

    .status-location,
    .status-coords,
    .status-clock {
      font-size: 9px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-bar { animation: none; }
  }
</style>
