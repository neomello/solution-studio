# Studio Odonto Official Hub · Environment Variables Example
# Referência de configuração e IDs oficiais do cliente: docs/META-config.md
# IMPORTANTE: Nunca commitar o arquivo .env com tokens e segredos reais.

# --- META DEVELOPERS APP & AD ACCOUNT ---
META_APP_ID="seu_app_id_aqui"
META_AD_ACCOUNT_ID="seu_ad_account_id_aqui"
META_APP_SECRET="sua_app_secret_aqui"

# --- META PIXEL & CONVERSIONS API (C-API) ---
# PUBLIC_ para exposição no frontend (quando habilitado no Astro)
PUBLIC_META_PIXEL_ID="seu_pixel_id_aqui"
# Token de acesso de longo prazo da Conversions API (server-side apenas)
META_API_TOKEN="EAAQ..."

# --- WHATSAPP BUSINESS & CLOUD API ---
WHATSAPP_ACCOUNT_ID="seu_whatsapp_account_id_aqui"
WHATSAPP_PHONE_NUMBER_ID="seu_whatsapp_phone_number_id_aqui"
WHATSAPP_PHONE_NUMBER="+55 62 99999-9999"

# --- FACEBOOK PAGE ---
FACEBOOK_PAGE_ID="seu_facebook_page_id_aqui"

# --- SITE CONFIG ---
PUBLIC_SITE_URL="https://seu-dominio.com"